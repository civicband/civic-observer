# Copy this file to .env and update values as needed
# For local development with Docker:
ALLOWED_HOSTS=*
DATABASE_URL=postgres://postgres@db/postgres
DJANGO_DEBUG=true
DJANGO_SETTINGS_MODULE=config.settings.development
DJANGO_PORT=8888

# API Key Validation (for corkboard service-to-service auth)
# Generate a secure random string for production
CORKBOARD_SERVICE_SECRET=

# Notification Channels (optional)
DISCORD_BOT_TOKEN=
BLUESKY_BOT_HANDLE=
BLUESKY_BOT_PASSWORD=
MASTODON_ACCESS_TOKEN=
MASTODON_INSTANCE_URL=https://mastodon.social

# Quickwit Configuration (search on S3 object storage)
SEARCH_BACKEND=quickwit
QUICKWIT_URL=http://quickwit:7280/api/v1
QUICKWIT_INDEX_ID=meeting_pages
QUICKWIT_TIMEOUT=30

# Fastly Object Storage (for Quickwit index data)
FASTLY_ACCESS_KEY_ID=
FASTLY_SECRET_ACCESS_KEY=
FASTLY_REGION=us-west
QUICKWIT_BUCKET=quickwit-civic-observer-staging
AWS_ENDPOINT_URL=https://us-west.object.fastlystorage.app
AWS_DEFAULT_REGION=us-west
